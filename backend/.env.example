# ============================================================
# Lokal v2 — Backend Environment Variables
# ============================================================
# Copy to .env and fill in values for your target environment.
#
# Environment guide:
#   development → local machine, NODE_ENV=development
#   staging     → Railway staging service, NODE_ENV=staging
#   production  → Railway production service, NODE_ENV=production
# ============================================================

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# "development" | "staging" | "production"
NODE_ENV=development

# Frontend URL — used for CORS allowlist + CSRF origin checks
#   development:  http://localhost:5173
#   staging:      https://lokalv2-git-staging-lokakhost.vercel.app
#   production:   https://your-custom-domain.com (or Vercel prod URL)
FRONTEND_URL=http://localhost:5173

# ─── Supabase ──────────────────────────────────────────────────────────────────
# ⚠️ Use the STAGING Supabase project for staging, PRODUCTION project for prod.
# From: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Prisma / PostgreSQL ───────────────────────────────────────────────────────
# Pooled connection (used by Prisma at runtime)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (used for migrations)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ─── GetStream.io ──────────────────────────────────────────────────────────────
# From: https://dashboard.getstream.io → Your App → Settings
# Shared across staging + production (same GetStream app)
GETSTREAM_API_KEY=your-getstream-api-key
GETSTREAM_API_SECRET=your-getstream-api-secret

# ─── AI Services ──────────────────────────────────────────────────────────────
# Shared across staging + production
OPENROUTER_API_KEY=your-openrouter-api-key
JINA_API_KEY=your-jina-api-key

# ─── Resend (Transactional Email) ─────────────────────────────────────────────
# From: https://resend.com → API Keys
RESEND_API_KEY=re_your-resend-api-key

# ─── OpenAI (Phase 3 — Semantic Feed Ranking) ─────────────────────────────────
# Used by Supabase Edge Functions for text-embedding-3-small
OPENAI_API_KEY=sk-your-openai-api-key
