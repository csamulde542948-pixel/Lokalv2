# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Supabase ──────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Prisma / PostgreSQL ───────────────────────────────────────────────────────
# Pooled connection (used by Prisma at runtime)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (used for migrations)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ─── GetStream.io ──────────────────────────────────────────────────────────────
# From: https://dashboard.getstream.io → Your App → Settings
GETSTREAM_API_KEY=your-getstream-api-key
GETSTREAM_API_SECRET=your-getstream-api-secret

# ─── Resend (Transactional Email) ─────────────────────────────────────────────
# From: https://resend.com → API Keys
RESEND_API_KEY=re_your-resend-api-key

# ─── OpenAI (Phase 3 — Semantic Feed Ranking) ─────────────────────────────────
# Used by Supabase Edge Functions for text-embedding-3-small
OPENAI_API_KEY=sk-your-openai-api-key
