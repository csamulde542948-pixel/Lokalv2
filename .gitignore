dist/
build/

# Environment files
# ─ .env.local        → your personal local secrets (never commit)
# ─ .env.*.local      → any local override of any mode (never commit)
# ─ .env              → raw .env with real secrets (never commit)
# ─ .env.staging      → IGNORED — contains real secrets, use Railway/Vercel dashboard
# ─ .env.production   → IGNORED — contains real secrets, use Railway/Vercel dashboard
# ─ .env.example      → COMMITTED — documented reference with placeholders only
.env
.env.local
.env.*.local
.env.staging
.env.production
backend/.env.staging
backend/.env.production

