# Environment files
# ─ .env.local        → your personal local secrets (never commit) ❌
# ─ .env              → local development secrets (never commit) ❌
# ─ .env.production   → PRODUCTION secrets (never commit) ❌
# ─ .env.staging      → STAGING secrets (never commit) ❌
# ─ .env.*.local      → any local override (never commit) ❌
# ─ .env.example      → template with placeholders (safe to commit) ✅
# ─ .env.*.example    → templates with placeholders (safe to commit) ✅
.env
.env.local
.env.production
.env.staging
.env.*.local
backend/.env
backend/.env.local
backend/.env.production
backend/.env.staging

